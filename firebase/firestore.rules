rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Check if user has admin role in their profile
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users_new/$(request.auth.uid)).data.role == "admin";
    }

    // User Profile Rules
    match /users_new/{userId} {
      // Anyone can read a profile (required for mentions/display)
      allow read: if isAuthenticated();
      // Only the user or an admin can update their own profile
      allow write: if (isAuthenticated() && request.auth.uid == userId) || isAdmin();
    }
    
    // Admission Records Rules
    match /admissions/{docId} {
      // Students can only read their own records (filtered by phoneNumber/email in logic)
      // Admins can read all. 
      // For strict privacy, ensure resource.data.phoneNumber == request.auth.token.phone_number (if available)
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      // Anyone can submit an admission form
      allow create: if true; 
      // Only admins can process/delete admissions
      allow update, delete: if isAdmin();
    }

    // Courses & Content Rules
    match /courses/{courseId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin(); // Only admins can modify courses
    }

    // Contact Messages
    match /contacts/{msgId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
